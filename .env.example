# RPC
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
BSC_TESTNET_RPC_URL=https://bsc-testnet-rpc.publicnode.com

# Foundry keystore account address (printed when you create the keystore)
DEPLOYER_ADDRESS=0xYourDeployerAddress

# Deploy mode: source (Sepolia) or dest (BSC Testnet)
BRIDGE_MODE=source

# Chainlink CCIP Router for the chain you are deploying to
# Sepolia:      0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59
# BSC Testnet:  0xE1053aE1857476f36A3C62580FF9b016E8EE8F6f
CCIP_ROUTER=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59

# Optional: contract verification
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
