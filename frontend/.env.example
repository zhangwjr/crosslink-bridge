# RPC (optional; falls back to viem public RPCs)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_BSC_TESTNET_RPC_URL=https://bsc-testnet-rpc.publicnode.com

# Sepolia (source)
NEXT_PUBLIC_SEPOLIA_BRIDGE_ADDRESS=0xYourSepoliaBridge
NEXT_PUBLIC_SEPOLIA_TOKEN_ADDRESS=0xYourSepoliaToken

# BSC Testnet (destination)
NEXT_PUBLIC_BSC_BRIDGE_ADDRESS=0xYourBscBridge
NEXT_PUBLIC_BSC_WRAPPED_TOKEN_ADDRESS=0xYourBscWrappedToken
